<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" prefWidth="280.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
    </padding>
    <children>
        <Label text="Dashboard">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>

        <Label text="Simulation speed" />
        <Slider fx:id="speedSlider" blockIncrement="0.1" majorTickUnit="1.0" max="5.0" min="0.1" showTickLabels="true" showTickMarks="true" value="1.0" />

        <Label text="Traffic light" />
        <Button fx:id="tlAutoBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Auto mode" />
        <Button fx:id="tlManualBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Manual mode" />
        <Button fx:id="tlNextPhaseBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Next phase" />

        <Label text="View" />
        <Button fx:id="zoomInBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Zoom in" />
        <Button fx:id="zoomOutBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Zoom out" />
        <Button fx:id="resetViewBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Reset view" />
    </children>
</VBox>